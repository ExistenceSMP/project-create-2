execute if score @s hud matches 2 run tellraw @s [{"text":"Enabling ","color":"gray"},{"text":"Action Bar HUD","color":"#4ab8ea"}]
execute if score @s hud matches 3 run tellraw @s [{"text":"Enabling ","color":"gray"},{"text":"Action Bar HUD","color":"#4ab8ea"},{"text":" with ","color":"gray"},{"text":"Compass","color":"#4ab8ea"}]
execute if score @s hud matches 4 run tellraw @s [{"text":"Enabling ","color":"gray"},{"text":"Action Bar HUD","color":"#4ab8ea"},{"text":" Light Text","color":"gray"}]
execute if score @s hud matches 5 run tellraw @s [{"text":"Enabling ","color":"gray"},{"text":"Action Bar HUD","color":"#4ab8ea"},{"text":" with ","color":"gray"},{"text":"Compass","color":"#4ab8ea"},{"text":" Light Text","color":"gray"}]
execute if score @s hud matches 6 run tellraw @s [{"text":"Enabling ","color":"gray"},{"text":"Action Bar HUD","color":"#4ab8ea"},{"text":" with ","color":"gray"},{"text":"Compass Weast","color":"#4ab8ea"}]
execute if score @s hud matches 7 run tellraw @s [{"text":"Enabling ","color":"gray"},{"text":"Action Bar HUD","color":"#4ab8ea"},{"text":" with ","color":"gray"},{"text":"Compass Weet-Bix","color":"#4ab8ea"}]
execute if score @s hud matches 2..7 run scoreboard players operation @s exi_hud = @s hud

execute if score @s hud matches -1 run tellraw @s [{"text":"Disabling ","color":"gray"},{"text":"Action Bar HUD","color":"#4ab8ea"}]
execute if score @s hud matches -1 run title @s actionbar [{"text":"Action Bar HUD ","color":"gray"},{"text":"Disabled","color":"red"}]
execute if score @s hud matches -1 run scoreboard players set @s exi_hud 0

execute as @s if score @s hud matches ..-2 run tellraw @s ["",{"text":"Error: Please enter a value between 2 and 7.","color":"red"}]
execute as @s if score @s hud matches 8.. run tellraw @s ["",{"text":"Error: Please enter a value between 2 and 7.","color":"red"}]

execute as @s if score @s hud matches 6 run advancement grant @s only existence_smp:hud/weast
execute as @s if score @s hud matches 7 run advancement grant @s only existence_smp:hud/weet-bix

scoreboard players set @s hud 0